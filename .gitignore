# =============================================================================
#  IoT Sandbox Dashboard — .gitignore
#  Covers: Node.js, React/Vite, Python, Docker volumes, OS, editors, secrets
# =============================================================================


# ── Credentials & secrets ─────────────────────────────────────────────────────
# NEVER commit real .env files — only .env.example (with dummy values) is safe.
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.cert
*.p12
*.pfx


# ── Node.js dependencies ──────────────────────────────────────────────────────
# node_modules can be fully restored via `npm install` — never commit them.
node_modules/
frontend/node_modules/
backend/node_modules/

# NPM / Yarn / PNPM debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Optional: lock files (uncomment if your team prefers not to commit them)
# package-lock.json
# yarn.lock


# ── Frontend build output ─────────────────────────────────────────────────────
# Generated by `npm run build` — rebuild from source, don't commit binaries.
frontend/dist/
frontend/build/
frontend/.vite/
.vite/


# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
simulator/venv/
simulator/.venv/

# Distribution / packaging
*.egg-info/
*.egg
.eggs/
dist/


# ── Docker volumes & runtime data ─────────────────────────────────────────────
# MySQL data written by docker-compose — never commit database files.
docker/mysql-data/
docker/data/
docker/mosquitto/data/
docker/mosquitto/log/

# Mosquitto persistence files (generated at runtime)
*.db
mosquitto.db


# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*


# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov


# ── Operating system files ────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ── Editor & IDE ──────────────────────────────────────────────────────────────
# VS Code — commit .vscode/extensions.json and .vscode/settings.json if needed,
# but ignore personal/machine-specific files.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (WebStorm, IntelliJ, CLion, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.swp
*.swo
.netrwhist

# Emacs
*~
\#*\#
.#*


# ── Temporary & misc ──────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
.cache/
tmp/
temp/


# ── Arduino / PlatformIO build artifacts ──────────────────────────────────────
# Compiled firmware and cache — always rebuilt from source.
arduino-library/.arduino15/
.pio/
.pioenvs/
.piolibdeps/
.clang_complete
.gcc-flags.json
# Added by code-review-graph
.code-review-graph/
