# ─────────────────────────────────────────────────────────────────────────────
# IoT Platform — Docker environment variables
# Copy this file to docker/.env and fill in your real values.
# docker/.env is automatically loaded by Docker Compose.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase Web App config (from Firebase Console → Project Settings → Your Apps)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Backend uses this to verify Firebase ID tokens (must match above project ID)
FIREBASE_PROJECT_ID=your-project-id

# ── Email / SMTP (required for OTP forgot-password and registration verify) ──
# Gmail example: enable "App Passwords" in your Google Account, then:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=muhdismaail@gmail.com
SMTP_PASS=zdmgzyefxhczoshp
