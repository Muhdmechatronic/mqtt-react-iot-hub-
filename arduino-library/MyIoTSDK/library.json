{
  "name": "MyIoTSDK",
  "version": "2.0.0",
  "description": "ESP32/ESP8266 client library for the IoT Platform. MQTT primary transport with automatic HTTP fallback. Full virtual pin system (V0–V255) for bidirectional dashboard synchronisation.",
  "keywords": ["iot", "mqtt", "http", "virtual-pin", "dashboard", "esp32", "esp8266", "blynk-like"],
  "authors": [
    {
      "name": "IoT Platform",
      "maintainer": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-repo/MyIoTSDK"
  },
  "license": "MIT",
  "frameworks": ["arduino"],
  "platforms": ["espressif32", "espressif8266"],
  "dependencies": [
    {
      "owner": "knolleary",
      "name": "PubSubClient",
      "version": ">=2.8"
    },
    {
      "owner": "bblanchon",
      "name": "ArduinoJson",
      "version": ">=6.0"
    }
  ],
  "examples": [
    "examples/BasicSensor/BasicSensor.ino",
    "examples/VirtualPins/VirtualPins.ino",
    "examples/FullSimulator/FullSimulator.ino"
  ]
}
